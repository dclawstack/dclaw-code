# DClaw Code Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dclaw_code

# AI Providers
OPENROUTER_API_KEY=          # Required for cloud models
OPENROUTER_URL=https://openrouter.ai/api/v1
OLLAMA_URL=http://localhost:11434
NVIDIA_API_KEY=              # Required for DeepSeek V4 via NVIDIA NIMs

# Auth (Logto) — leave empty if not using SSO
LOGTO_ENDPOINT=
LOGTO_AUDIENCE=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8094/api
CORS_ORIGINS=http://localhost:3005,http://localhost:3000
